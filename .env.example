# ---------------------------------------------------------------------------
# Copy to `.env.local` and fill in. `.env.local` is gitignored — never commit it.
# ---------------------------------------------------------------------------

# Public origin of the app. Used for canonical URLs, sitemap, and OG images.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Session signing
# ---------------------------------------------------------------------------
# HS256 key for the session JWT. MUST be at least 32 characters.
# The app refuses to start without it — there is no insecure fallback.
# Generate one with:  openssl rand -base64 48
AUTH_SECRET=""

# Session lifetime in seconds. Default: 86400 (24 hours).
AUTH_SESSION_MAX_AGE="86400"

# ---------------------------------------------------------------------------
# Mock data layer
# ---------------------------------------------------------------------------
# Seed for the deterministic analytics generator. The same seed always yields
# the same numbers, which keeps snapshots and E2E assertions stable.
ANALYTICS_SEED="20260101"
